#!/bin/bash
# resolution

# 20260306
# 0.2.0

DEFAULT_REFRESH=60

usage() {
  echo "resolution - Add a display resolution mode via xrandr."
  echo
  echo "Usage: resolution [options] WIDTH x HEIGHT [@ REFRESH]"
  echo "       resolution [options] WIDTHxHEIGHT[@REFRESH]"
  echo "       resolution [options] WIDTH HEIGHT [REFRESH]"
  echo
  echo "If REFRESH is not given, defaults to 60Hz."
  echo
  echo "Options:"
  echo "  -o, --output OUTPUT  Specify xrandr output (default: auto-detect DP)"
  echo "  -p, --persist        Write to ~/.xprofile for persistence across reboots"
  echo "  -n, --dry-run        Show what would happen without doing it"
  echo "  -h, --help           Show this help"
  echo
  echo "Examples:"
  echo "  resolution 1920 x 1080 @ 60"
  echo "  resolution 2560 x 1600"
  echo "  resolution 2560x1600@60"
  echo "  resolution 2560x1600"
  echo "  resolution 2560 1600 60"
  echo "  resolution 2560 1600"
}

parse_resolution() {
  local joined
  joined=$(echo "$@" | tr -d ' ')
  local w h r
  if echo "$joined" | grep -q '[xX]'; then
    w=$(echo "$joined" | sed 's/[xX].*//')
    local remainder
    remainder=$(echo "$joined" | sed 's/^[0-9]*[xX]//')
    if echo "$remainder" | grep -q '@'; then
      h=$(echo "$remainder" | sed 's/@.*//')
      r=$(echo "$remainder" | sed 's/.*@//')
    else
      h="$remainder"
      r=""
    fi
  else
    w="$1"
    h="$2"
    r="$3"
  fi
  if [ -z "$w" ] || [ -z "$h" ]; then
    return 1
  fi
  WIDTH="$w"
  HEIGHT="$h"
  REFRESH="${r:-$DEFAULT_REFRESH}"
}

detect_output() {
  xrandr | grep ' connected' | grep -i 'dp\|displayport' | head -1 | awk '{print $1}'
}

generate_modeline() {
  if command -v cvt > /dev/null 2>&1; then
    cvt "$WIDTH" "$HEIGHT" "$REFRESH" | grep 'Modeline' | sed 's/.*Modeline //' | tr -d '"'
  elif command -v gtf > /dev/null 2>&1; then
    gtf "$WIDTH" "$HEIGHT" "$REFRESH" | grep 'Modeline' | sed 's/.*Modeline //' | tr -d '"'
  else
    echo "Error: Neither cvt nor gtf found." >&2
    return 1
  fi
}

mode_name() {
  echo "${WIDTH}x${HEIGHT}_${REFRESH}.00"
}

apply_mode() {
  local output="$1"
  local modeline="$2"
  local name
  name=$(mode_name)
  if [ "$DRY_RUN" = true ]; then
    echo "Would run:"
    echo "  xrandr --newmode $modeline"
    echo "  xrandr --addmode $output $name"
    echo "  xrandr --output $output --mode $name"
    return
  fi
  xrandr --newmode $modeline 2>/dev/null
  xrandr --addmode "$output" "$name"
  xrandr --output "$output" --mode "$name"
}

persist_mode() {
  local output="$1"
  local modeline="$2"
  local name
  name=$(mode_name)
  local xprofile="$HOME/.xprofile"
  local marker="# resolution: ${WIDTH}x${HEIGHT}"
  if [ "$DRY_RUN" = true ]; then
    echo "Would append to $xprofile:"
    echo "  xrandr --newmode $modeline"
    echo "  xrandr --addmode $output $name"
    echo "  xrandr --output $output --mode $name"
    return
  fi
  if [ -f "$xprofile" ] && grep -q "$marker" "$xprofile"; then
    echo "$xprofile already contains an entry for ${WIDTH}x${HEIGHT}. Skipping."
    return
  fi
  {
    echo
    echo "$marker"
    echo "xrandr --newmode $modeline 2>/dev/null"
    echo "xrandr --addmode $output $name"
    echo "xrandr --output $output --mode $name"
  } >> "$xprofile"
  echo "Persisted to $xprofile."
}

main() {
  local output=""
  local persist=false
  local args=""
  DRY_RUN=false
  while [ $# -gt 0 ]; do
    case "$1" in
      -o|--output) output="$2"; shift 2;;
      -p|--persist) persist=true; shift;;
      -n|--dry-run) DRY_RUN=true; shift;;
      -h|--help) usage; exit 0;;
      -*) echo "Unknown option: $1"; usage; exit 1;;
      *) args="$args $1"; shift;;
    esac
  done
  args=$(echo "$args" | sed 's/^ //')
  if [ -z "$args" ]; then
    usage
    exit 1
  fi
  parse_resolution $args
  if [ $? -ne 0 ]; then
    usage
    exit 1
  fi
  echo "Resolution: ${WIDTH}x${HEIGHT}@${REFRESH}Hz"
  if [ -z "$output" ]; then
    output=$(detect_output)
    if [ -z "$output" ]; then
      echo "Error: No DisplayPort output detected. Use -o to specify manually." >&2
      exit 1
    fi
    echo "Auto-detected output: $output"
  fi
  local modeline
  modeline=$(generate_modeline)
  if [ -z "$modeline" ]; then
    echo "Error: Failed to generate modeline." >&2
    exit 1
  fi
  echo "Modeline: $modeline"
  apply_mode "$output" "$modeline"
  if [ "$persist" = true ]; then
    persist_mode "$output" "$modeline"
  fi
}

main "$@"
