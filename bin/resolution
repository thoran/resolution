#!/bin/bash
# resolution

# 20260306
# 0.0.0

# Initial:
# -/0: Enable setting the ideal resolution for an HP ZR30W for Linux Mint out of the box.
# 1. Use fixed 2560 width, 1600 height, and 60Hz refresh.
# 2. Use `gtf` for detection.
# 3. + --output specify the display.
# 4. + --persist persist the mode for reboots.
# 5. + --dry-run
# 6. + --help

WIDTH=2560
HEIGHT=1600
REFRESH=60

usage() {
  echo "resolution - Set display to ${WIDTH}x${HEIGHT}@${REFRESH}Hz via xrandr."
  echo
  echo "Usage: resolution [options]"
  echo
  echo "Options:"
  echo "  -o, --output OUTPUT  Specify xrandr output (default: auto-detect DP)"
  echo "  -p, --persist        Write to ~/.xprofile for persistence across reboots"
  echo "  -n, --dry-run        Show what would happen without doing it"
  echo "  -h, --help           Show this help"
}

detect_output() {
  xrandr | grep ' connected' | grep -i 'dp\|displayport' | head -1 | awk '{print $1}'
}

generate_modeline() {
  gtf "$WIDTH" "$HEIGHT" "$REFRESH" | grep 'Modeline' | sed 's/.*Modeline //' | tr -d '"'
}

mode_name() {
  echo "${WIDTH}x${HEIGHT}_${REFRESH}.00"
}

apply_mode() {
  local output="$1"
  local modeline="$2"
  local name
  name=$(mode_name)
  if [ "$DRY_RUN" = true ]; then
    echo "Would run:"
    echo "  xrandr --newmode $modeline"
    echo "  xrandr --addmode $output $name"
    echo "  xrandr --output $output --mode $name"
    return
  fi
  xrandr --newmode $modeline 2>/dev/null
  xrandr --addmode "$output" "$name"
  xrandr --output "$output" --mode "$name"
}

persist_mode() {
  local output="$1"
  local modeline="$2"
  local name
  name=$(mode_name)
  local xprofile="$HOME/.xprofile"
  local marker="# resolution: ${WIDTH}x${HEIGHT}"
  if [ "$DRY_RUN" = true ]; then
    echo "Would append to $xprofile:"
    echo "  xrandr --newmode $modeline"
    echo "  xrandr --addmode $output $name"
    echo "  xrandr --output $output --mode $name"
    return
  fi
  if [ -f "$xprofile" ] && grep -q "$marker" "$xprofile"; then
    echo "$xprofile already contains an entry for ${WIDTH}x${HEIGHT}. Skipping."
    return
  fi
  {
    echo
    echo "$marker"
    echo "xrandr --newmode $modeline 2>/dev/null"
    echo "xrandr --addmode $output $name"
    echo "xrandr --output $output --mode $name"
  } >> "$xprofile"
  echo "Persisted to $xprofile."
}

main() {
  local output=""
  local persist=false
  DRY_RUN=false
  while [ $# -gt 0 ]; do
    case "$1" in
      -o|--output) output="$2"; shift 2;;
      -p|--persist) persist=true; shift;;
      -n|--dry-run) DRY_RUN=true; shift;;
      -h|--help) usage; exit 0;;
      *) echo "Unknown option: $1"; usage; exit 1;;
    esac
  done
  if [ -z "$output" ]; then
    output=$(detect_output)
    if [ -z "$output" ]; then
      echo "Error: No DisplayPort output detected. Use -o to specify manually." >&2
      exit 1
    fi
    echo "Auto-detected output: $output"
  fi
  local modeline
  modeline=$(generate_modeline)
  if [ -z "$modeline" ]; then
    echo "Error: Failed to generate modeline. Is gtf installed?" >&2
    exit 1
  fi
  echo "Modeline: $modeline"
  apply_mode "$output" "$modeline"
  if [ "$persist" = true ]; then
    persist_mode "$output" "$modeline"
  fi
}

main "$@"
